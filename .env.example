# Database Configuration
DB_NAME=stadium_db
MYSQL_ROOT_PASSWORD=your_secure_root_password

# Redis Configuration
REDIS_PASSWORD=your_redis_auth_password

# Security & JWT Configuration
# Use a secure random string (at least 32 characters for HS256)
JWT_SECRET=a_very_long_and_secure_secret_key_at_least_32_chars
JWT_ISSUER=stadium-booking-system

# Server Configuration (Optional for Local)
PORT=7860